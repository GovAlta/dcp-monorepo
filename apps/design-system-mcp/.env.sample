# Environment
MCP_TRANSPORT=stdio           # or "http"
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=*

# Rate Limiting
GOA_RATE_LIMIT=60             # tool calls per minute, sliding window

# Logging
GOA_LOG_LEVEL=info            # RFC 5424: debug|info|notice|warning|error|critical|alert|emergency
GOA_LOG_ARGS=false            # Log full tool args (security-sensitive)
GOA_CORRELATION_ID=           # Optional trace ID

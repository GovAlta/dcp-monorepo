{
  "extends": ["../../.eslintrc.json"],
  "ignorePatterns": ["!**/*", "templates/**", "scripts/**", "data/**"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {}
    },
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {
        "import/no-unresolved": ["error", { "ignore": ["@modelcontextprotocol/sdk", "@dcp-monorepo/mcp-common"] }]
      }
    },
    {
      "files": ["*.js", "*.jsx"],
      "rules": {}
    }
  ]
}

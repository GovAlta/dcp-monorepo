      "description": "Show error state",
      "frameworks": {
        "webComponent": "error=\"true\"",
        "react": "error={true}",
        "angular": "[error]=\"true\""
      }
    },
    {
      "name": "multiselect",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Allow multiple selections",
      "frameworks": {
        "webComponent": "multiselect=\"true\"",
        "react": "multiselect={true}",
        "angular": "[multiselect]=\"true\""
      }
    },
    {
      "name": "native",
      "type": "boolean",
      "required": false,
      "default": "false",

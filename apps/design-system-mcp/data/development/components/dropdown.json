      "description": "Margin top",
      "frameworks": {
        "webComponent": "mt=\"...\"",
        "react": "mt={...}",
        "angular": "[mt]=\"...\""
      }
    },
    {
      "name": "mr",
      "type": "Spacing",
      "required": false,
      "default": null,
      "description": "Margin right",
      "frameworks": {
        "webComponent": "mr=\"...\"",
        "react": "mr={...}",
        "angular": "[mr]=\"...\""
      }
    },
    {
      "name": "mb",
      "type": "Spacing",
      "required": false,
      "default": null,
      "description": "Margin bottom",
      "frameworks": {
        "webComponent": "mb=\"...\"",
        "react": "mb={...}",
        "angular": "[mb]=\"...\""
      }
    },
    {
      "name": "ml",
      "type": "Spacing",
      "required": false,
      "default": null,
      "description": "Margin left",
      "frameworks": {
        "webComponent": "ml=\"...\"",
        "react": "ml={...}",
        "angular": "[ml]=\"...\""
      }
    },
    {
      "name": "autoComplete",
      "type": "string",
      "required": false,
      "default": "",
      "description": "",
      "frameworks": {
        "webComponent": "auto-complete=\"...\"",
        "react": "autoComplete={...}",
        "angular": "[autoComplete]=\"...\""
      }
    },
    {
      "name": "testId",
      "type": "string",
      "required": false,
      "default": "",
      "description": "Test identifier",
      "frameworks": {
        "webComponent": "test-id=\"...\"",
        "react": "testId={...}",
        "angular": "[testId]=\"...\""
      }
    },
    {
      "name": "disableGlobalClosePopover",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "",
      "frameworks": {
        "webComponent": "disable-global-close-popover=\"...\"",
        "react": "disableGlobalClosePopover={...}",
        "angular": "[disableGlobalClosePopover]=\"...\""
      }
    }
  ],
  "dropdownItemProps": [
    {
      "name": "value",
      "type": "string",
      "required": true,
      "description": "Value for this option"
    },
    {
      "name": "label",
      "type": "string",
      "required": false,
      "description": "Display text (defaults to content)"
    }
  ],
  "events": [
    {
      "name": "_change",
      "type": "(event) => void",
      "payload": "{ name",
      "description": "",
      "frameworks": {
        "webComponent": "_change custom event",
        "react": "onChange prop",
        "angular": "(onChange) event binding"
      }
    }
  ],
  "slots": [
    {
      "name": "default",
      "description": "GoabDropdownItem components"
    }
  ],
  "criticalNotes": [
    "Always wrap in GoabFormItem for proper labeling",
    "NEVER add width prop unless explicitly required by design",
    "ariaLabel required when not wrapped in FormItem",
    "multiselect changes payload from string to string[]"
  ],
  "basicUsage": {
    "webComponent": "<goa-form-item label=\"Province\">\n  <goa-dropdown name=\"province\" placeholder=\"Select a province\">\n    <goa-dropdown-item value=\"AB\">Alberta</goa-dropdown-item>\n    <goa-dropdown-item value=\"BC\">British Columbia</goa-dropdown-item>\n  </goa-dropdown>\n</goa-form-item>",
    "react": "<GoabFormItem label=\"Province\">\n  <GoabDropdown\n    name=\"province\"\n    value={province}\n    placeholder=\"Select a province\"\n    onChange={(detail) => setProvince(detail.value)}\n  >\n    <GoabDropdownItem value=\"AB\">Alberta</GoabDropdownItem>\n    <GoabDropdownItem value=\"BC\">British Columbia</GoabDropdownItem>\n  </GoabDropdown>\n</GoabFormItem>",
    "angular": "<goab-form-item label=\"Province\">\n  <goab-dropdown\n    name=\"province\"\n    [value]=\"province\"\n    placeholder=\"Select a province\"\n    (onChange)=\"onProvinceChange($event)\">\n    <goab-dropdown-item value=\"AB\">Alberta</goab-dropdown-item>\n    <goab-dropdown-item value=\"BC\">British Columbia</goab-dropdown-item>\n  </goab-dropdown>\n</goab-form-item>"
  },
  "relatedExamples": [
    "dynamically-add-an-item-to-a-dropdown-list",
    "dynamically-change-items-in-a-dropdown-list",
    "show-number-of-results-per-page"
  ],

{
  "name": "Dropdown",
  "category": "form",
  "summary": "Selection component for choosing from predefined options. Always wrap in FormItem for proper labeling.",
  "import": "import { GoabDropdown, GoabDropdownItem } from '@abgov/react-components'",
  "customElement": {
    "tagName": "goa-dropdown",
    "reactName": "GoabDropdown",
    "angularSelector": "goab-dropdown"
  },
  "subComponents": {
    "dropdownItem": {
      "tagName": "goa-dropdown-item",
      "reactName": "GoabDropdownItem",
      "angularSelector": "goab-dropdown-item"
    }
  },
  "props": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "default": null,
      "description": "Form field identifier",
      "frameworks": {
        "webComponent": "name=\"...\"",
        "react": "name={...}",
        "angular": "[name]=\"...\""
      }
    },
    {
      "name": "ariaLabel",
      "type": "string",
      "required": false,
      "default": "",
      "description": "Accessible label when no visible label",
      "frameworks": {
        "webComponent": "aria-label=\"...\"",
        "react": "ariaLabel={...}",
        "angular": "[ariaLabel]=\"...\""
      }
    },
    {
      "name": "ariaLabelledBy",
      "type": "string",
      "required": false,
      "default": "",
      "description": "",
      "frameworks": {
        "webComponent": "aria-labelled-by=\"...\"",
        "react": "ariaLabelledBy={...}",
        "angular": "[ariaLabelledBy]=\"...\""
      }
    },
    {
      "name": "value",
      "type": "string | undefined",
      "required": false,
      "default": "",
      "description": "Currently selected value",
      "frameworks": {
        "webComponent": "value=\"...\"",
        "react": "value={...}",
        "angular": "[value]=\"...\""
      }
    },
    {
      "name": "filterable",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Enable search/filter",
      "frameworks": {
        "webComponent": "filterable=\"true\"",
        "react": "filterable={true}",
        "angular": "[filterable]=\"true\""
      }
    },
    {
      "name": "leadingIcon",
      "type": "GoAIconType",
      "required": false,
      "default": null,
      "description": "Icon on left side",
      "frameworks": {
        "webComponent": "leading-icon=\"...\"",
        "react": "leadingIcon={...}",
        "angular": "[leadingIcon]=\"...\""
      }
    },
    {
      "name": "maxHeight",
      "type": "string",
      "required": false,
      "default": "276px",
      "description": "Max height of options menu",
      "frameworks": {
        "webComponent": "max-height=\"...\"",
        "react": "maxHeight={...}",
        "angular": "[maxHeight]=\"...\""
      }
    },
    {
      "name": "placeholder",
      "type": "string",
      "required": false,
      "default": "",
      "description": "Text when no option selected",
      "frameworks": {
        "webComponent": "placeholder=\"...\"",
        "react": "placeholder={...}",
        "angular": "[placeholder]=\"...\""
      }
    },
    {
      "name": "width",
      "type": "string",
      "required": false,
      "default": "",
      "description": "",
      "frameworks": {
        "webComponent": "width=\"...\"",
        "react": "width={...}",
        "angular": "[width]=\"...\""
      }
    },
    {
      "name": "maxWidth",
      "type": "string",
      "required": false,
      "default": "",
      "description": "",
      "frameworks": {
        "webComponent": "max-width=\"...\"",
        "react": "maxWidth={...}",
        "angular": "[maxWidth]=\"...\""
      }
    },
    {
      "name": "disabled",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Disable interaction",
      "frameworks": {
        "webComponent": "disabled=\"true\"",
        "react": "disabled={true}",
        "angular": "[disabled]=\"true\""
      }
    },
    {
      "name": "error",
      "type": "boolean",
      "required": false,

{
  "name": "Block",
  "category": "layout",
  "summary": "Flexible layout container for grouping components with consistent spacing and alignment.",
  "import": "import { GoabBlock } from '@abgov/react-components'",
  "customElement": {
    "tagName": "goa-block",
    "reactName": "GoabBlock",
    "angularSelector": "goab-block"
  },
  "props": [
    {
      "name": "gap",
      "type": "Spacing",
      "required": false,
      "default": "m",
      "description": "Spacing between items",
      "frameworks": {
        "webComponent": "gap=\"...\"",
        "react": "gap={...}",
        "angular": "[gap]=\"...\""
      }
    },
    {
      "name": "direction",
      "type": "\"row\" | \"column\"",
      "required": false,
      "default": "row",
      "description": "Layout direction (horizontal or vertical)",
      "frameworks": {
        "webComponent": "direction=\"...\"",
        "react": "direction={...}",
        "angular": "[direction]=\"...\""
      }
    },
    {
      "name": "alignment",
      "type": "\"center\" | \"start\" | \"end\" | \"normal\"",
      "required": false,
      "default": "normal",
      "description": "How items align along main axis",
      "frameworks": {
        "webComponent": "alignment=\"...\"",
        "react": "alignment={...}",
        "angular": "[alignment]=\"...\""
      }
    },

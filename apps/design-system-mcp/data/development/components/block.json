  "criticalNotes": [
    "Use Block for general layout, ButtonGroup for related action buttons",
    "Default gap='m' provides balanced spacing for most use cases",
    "Use direction='column' for vertical stacking"
  ],
  "basicUsage": {
    "webComponent": "<goa-block gap=\"m\" direction=\"row\">\n  <goa-button>Save</goa-button>\n  <goa-button type=\"secondary\">Cancel</goa-button>\n</goa-block>",
    "react": "<GoabBlock gap=\"m\" direction=\"row\">\n  <GoabButton>Save</GoabButton>\n  <GoabButton type=\"secondary\">Cancel</GoabButton>\n</GoabBlock>",
    "angular": "<goab-block gap=\"m\" direction=\"row\">\n  <goab-button>Save</goab-button>\n  <goab-button type=\"secondary\">Cancel</goab-button>\n</goab-block>"
  },

  "events": [],
  "slots": [],
  "criticalNotes": [
    "Use ONLY valid Ionicons names - invalid names silently fail to render",
    "Common invalid names: 'dashboard' (use 'home'), 'bell' (use 'notifications'), 'logout' (use 'log-out')",
    "Provide ariaLabel when icon conveys meaning (not just decoration)",
    "Use design tokens for fillColor: var(--goa-color-interactive-primary)",
    "Browse full icon list at https://ionic.io/ionicons",
    "CRITICAL: Ionicons CDN must be included in index.html for icons to render"
  ],
  "basicUsage": {
    "webComponent": "<goa-icon type=\"warning\" size=\"3\" theme=\"filled\"></goa-icon>",
    "react": "<GoabIcon type=\"warning\" size={3} theme=\"filled\" />",
    "angular": "<goab-icon type=\"warning\" size=\"3\" theme=\"filled\"></goab-icon>"
  },
  "relatedExamples": [],
  "relatedComponents": [
    "IconButton",
    "Badge"
  ],
  "iconReference": {
    "totalIcons": "168+",
    "library": "Ionicons-based custom set for government services",
    "browseAt": "https://ionic.io/ionicons",
    "cdnRequired": {
      "description": "Icons require Ionicons CDN in index.html to render",
      "scripts": [
        "<script type=\"module\" src=\"https://cdn.jsdelivr.net/npm/ionicons@5.5.2/dist/ionicons/ionicons.esm.js\"></script>",
        "<script nomodule src=\"https://cdn.jsdelivr.net/npm/ionicons@5.5.2/dist/ionicons/ionicons.js\"></script>"
      ],
      "placement": "Add inside <head> tag"
    },
    "commonIcons": {
      "navigation": ["home", "menu", "close", "arrow-back", "arrow-forward", "chevron-back", "chevron-forward", "chevron-down", "chevron-up"],
      "actions": ["add", "create", "trash", "pencil", "save", "download", "upload", "search", "filter", "refresh"],
      "status": ["checkmark-circle", "close-circle", "alert-circle", "warning", "information-circle", "help-circle"],
      "communication": ["call", "mail", "chatbubble", "notifications", "log-out"],
      "files": ["document", "document-text", "folder", "attach", "link"],
      "government": ["business", "briefcase", "calendar", "location", "people", "person", "settings"]
    },
    "invalidIconNames": {
      "description": "These commonly-used names are INVALID and will not render",
      "invalidToValid": {
        "dashboard": "home",
        "bell": "notifications",
        "logout": "log-out",
        "archive": "folder",
        "question-circle": "help-circle",
        "edit": "pencil",
        "delete": "trash"
      }
    },
    "namingPattern": "kebab-case: [object]-[modifier]-[variant] (e.g., arrow-forward, checkmark-circle, trash-outline)"
  }
}
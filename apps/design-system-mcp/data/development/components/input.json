  "criticalNotes": [
    "ALWAYS wrap Input in GoabFormItem for proper labeling and validation",
    "Must explicitly set width prop for variable length content (width='100%')",
    "Use FormItem mb prop for spacing, not GoabSpacer after Input",
    "Text inputs do NOT default to 100% width - must be explicitly set"
  ],
  "commonMistakes": [
    {
      "mistake": "<GoabInput> without <GoabFormItem> wrapper",
      "fix": "Always wrap: <GoabFormItem label='...'><GoabInput /></GoabFormItem>"
    },
    {
      "mistake": "Missing width prop on text inputs",
      "fix": "Add width='100%' for variable length, or specific width for fixed data"
    },
    {
      "mistake": "Using GoabSpacer after FormItem for spacing",
      "fix": "Use FormItem mb prop instead"
    }
  ],
  "inputWidthStrategy": {
    "fixedWidths": {
      "postalCode": "7ch",
      "suiteUnit": "10ch",
      "year": "4ch",
      "age": "3ch",
      "areaCode": "3ch",
      "sin": "11ch",
      "cvc": "3ch"
    },
    "fullWidth": {
      "rule": "Use width='100%' for unknown/variable length content",
      "applies": [
        "Street addresses",
        "City names",
        "Names (first, last, business)",
        "Email addresses"
      ]
    },
    "textAreaThreshold": "Use TextArea instead of Input for content longer than 45-75 characters"
  },
  "basicUsage": {
    "webComponent": "<goa-form-item label=\"Email address\" mb=\"l\">\n  <goa-input name=\"email\" type=\"email\" width=\"100%\"></goa-input>\n</goa-form-item>",
    "react": "<GoabFormItem label=\"Email address\" mb=\"l\">\n  <GoabInput\n    name=\"email\"\n    type=\"email\"\n    width=\"100%\"\n    value={email}\n    onChange={(detail) => setEmail(detail.value)}\n  />\n</GoabFormItem>",
    "angular": "<goab-form-item label=\"Email address\" mb=\"l\">\n  <goab-input\n    name=\"email\"\n    type=\"email\"\n    width=\"100%\"\n    [value]=\"email\"\n    (onChange)=\"onEmailChange($event)\">\n  </goab-input>\n</goab-form-item>"
  },

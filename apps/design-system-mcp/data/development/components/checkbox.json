{
  "name": "Checkbox",
  "category": "form",
  "summary": "Interactive checkbox for multi-selection scenarios. Always wrap in FormItem for proper labeling.",
  "import": "import { GoabCheckbox } from '@abgov/react-components'",
  "customElement": {
    "tagName": "goa-checkbox",
    "reactName": "GoabCheckbox",
    "angularSelector": "goab-checkbox"
  },
  "props": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "default": null,
      "description": "Unique identifier for form submission",
      "frameworks": {
        "webComponent": "name=\"...\"",
        "react": "name={...}",
        "angular": "[name]=\"...\""
      }
    },
    {
      "name": "checked",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Whether checkbox is selected",
      "frameworks": {
        "webComponent": "checked=\"true\"",
        "react": "checked={true}",
        "angular": "[checked]=\"true\""
      }
    },
    {
      "name": "indeterminate",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "",
      "frameworks": {
        "webComponent": "indeterminate=\"true\"",
        "react": "indeterminate={true}",
        "angular": "[indeterminate]=\"true\""
      }
    },
    {
      "name": "text",
      "type": "string",
      "required": false,
      "default": "",
      "description": "Label text next to checkbox",
      "frameworks": {
        "webComponent": "text=\"...\"",
        "react": "text={...}",
        "angular": "[text]=\"...\""
      }
    },
    {
      "name": "value",
      "type": "string",
      "required": false,
      "default": "",
      "description": "Value sent when checked",
      "frameworks": {
        "webComponent": "value=\"...\"",
        "react": "value={...}",
        "angular": "[value]=\"...\""
      }
    },
    {
      "name": "disabled",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Prevents interaction",
      "frameworks": {
        "webComponent": "disabled=\"true\"",
        "react": "disabled={true}",
        "angular": "[disabled]=\"true\""
      }
    },
    {
      "name": "error",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Shows error styling",
      "frameworks": {
        "webComponent": "error=\"true\"",
        "react": "error={true}",
        "angular": "[error]=\"true\""
      }
    },
    {
      "name": "testId",
      "type": "string",
      "required": false,
      "default": "",
      "description": "Test identifier",
      "frameworks": {
        "webComponent": "test-id=\"...\"",
        "react": "testId={...}",
        "angular": "[testId]=\"...\""
      }
    },
    {
      "name": "ariaLabel",
      "type": "string",
      "required": false,
      "default": "",
      "description": "Accessible label for screen readers",
      "frameworks": {
        "webComponent": "aria-label=\"...\"",
        "react": "ariaLabel={...}",
        "angular": "[ariaLabel]=\"...\""
      }
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "default": "",
      "description": "Additional text below label",
      "frameworks": {
        "webComponent": "description=\"...\"",
        "react": "description={...}",
        "angular": "[description]=\"...\""
      }
    },
    {
      "name": "revealarialabel",
      "type": "string",
      "required": false,
      "default": "",
      "description": "",
      "frameworks": {
        "webComponent": "revealarialabel=\"...\"",
        "react": "revealarialabel={...}",
        "angular": "[revealarialabel]=\"...\""
      }
    },
    {
      "name": "maxWidth",
      "type": "string",
      "required": false,
      "default": "none",
      "description": "",
      "frameworks": {
        "webComponent": "max-width=\"...\"",
        "react": "maxWidth={...}",
        "angular": "[maxWidth]=\"...\""
      }
    },
    {
      "name": "size",
      "type": "\"default\" | \"compact\"",
      "required": false,
      "default": "default",
      "description": "",
      "frameworks": {
        "webComponent": "size=\"...\"",
        "react": "size={...}",
        "angular": "[size]=\"...\""
      }
    },
    {
      "name": "mt",
      "type": "Spacing",
      "required": false,
      "default": null,
      "description": "Margin top",
      "frameworks": {
        "webComponent": "mt=\"...\"",
        "react": "mt={...}",
        "angular": "[mt]=\"...\""
      }
    },
    {
      "name": "mr",
      "type": "Spacing",
      "required": false,
      "default": null,
      "description": "Margin right",
      "frameworks": {
        "webComponent": "mr=\"...\"",
        "react": "mr={...}",
        "angular": "[mr]=\"...\""
      }
    },
    {
      "name": "mb",
      "type": "Spacing",
      "required": false,
      "default": null,
      "description": "Margin bottom",
      "frameworks": {
        "webComponent": "mb=\"...\"",
        "react": "mb={...}",
        "angular": "[mb]=\"...\""
      }
    },
    {
      "name": "ml",
      "type": "Spacing",
      "required": false,
      "default": null,
      "description": "Margin left",
      "frameworks": {
        "webComponent": "ml=\"...\"",
        "react": "ml={...}",
        "angular": "[ml]=\"...\""
      }
    }
  ],
  "events": [
    {
      "name": "_change",
      "type": "(event) => void",
      "payload": "{ name",
      "description": "",
      "frameworks": {
        "webComponent": "_change custom event",
        "react": "onChange prop",
        "angular": "(onChange) event binding"
      }
    },
    {
      "name": "_revealChange",
      "type": "(event) => void",
      "payload": "eventDetail",
      "description": "",
      "frameworks": {
        "webComponent": "_revealChange custom event",
        "react": "onRevealChange prop",
        "angular": "(onRevealChange) event binding"
      }
    }
  ],
  "slots": [
    {
      "name": "description",
      "description": ""
    },
    {
      "name": "reveal",
      "description": ""
    },
    {
      "name": "default",
      "description": ""
    }
  ],
  "criticalNotes": [
    "Wrap checkbox groups in GoabFormItem for proper labeling",
    "Use description prop for additional context on complex options",
    "Default mb='m' provides standard spacing between checkboxes"
  ],
  "basicUsage": {
    "webComponent": "<goa-checkbox name=\"terms\" text=\"I agree to the terms and conditions\" checked=\"false\"></goa-checkbox>",
    "react": "<GoabCheckbox\n  name=\"terms\"\n  text=\"I agree to the terms and conditions\"\n  checked={agreed}\n  onChange={(detail) => setAgreed(detail.checked)}\n/>",
    "angular": "<goab-checkbox\n  name=\"terms\"\n  text=\"I agree to the terms and conditions\"\n  [checked]=\"agreed\"\n  (onChange)=\"onAgree($event)\">\n</goab-checkbox>"
  },
  "relatedExamples": [
    "select-one-or-more-from-a-list-of-options",
    "include-descriptions-for-items-in-a-checkbox-list",
    "reveal-more-information-to-help-answer-a-question"
  ],

        "react": "onChange prop",
        "angular": "(onChange) event binding"
      }
    },
    {
      "name": "goa:closePopover",
      "type": "(event) => void",
      "payload": "{ target: _rootEl }",
      "description": "",
      "frameworks": {
        "webComponent": "goa:closePopover custom event",
        "react": "onGoa:closePopover prop",
        "angular": "(onGoa:closePopover) event binding"
      }

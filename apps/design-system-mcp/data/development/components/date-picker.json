  "slots": [],
  "criticalNotes": [
    "Always wrap in GoabFormItem for proper labeling",
    "Handle both Date objects and undefined values in onChange",
    "Set appropriate min/max for your use case (e.g., birthdate vs future dates)"
  ],
  "basicUsage": {
    "webComponent": "<goa-form-item label=\"Date of birth\">\n  <goa-date-picker name=\"dob\" max=\"today\"></goa-date-picker>\n</goa-form-item>",
    "react": "<GoabFormItem label=\"Date of birth\">\n  <GoabDatePicker\n    name=\"dob\"\n    value={dateOfBirth}\n    max={new Date()}\n    onChange={(detail) => setDateOfBirth(detail.value)}\n  />\n</GoabFormItem>",
    "angular": "<goab-form-item label=\"Date of birth\">\n  <goab-date-picker\n    name=\"dob\"\n    [value]=\"dateOfBirth\"\n    [max]=\"today\"\n    (onChange)=\"onDateChange($event)\">\n  </goab-date-picker>\n</goab-form-item>"
  },
  "relatedExamples": [

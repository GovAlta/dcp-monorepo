    "tagName": "goa-date-picker",
    "reactName": "GoabDatePicker",
    "angularSelector": "goab-date-picker"
  },
  "props": [
    {
      "name": "type",
      "type": "\"calendar\" | \"input\"",
      "required": false,
      "default": "calendar",
      "description": "calendar = popup, input = separate dropdowns",
      "frameworks": {
        "webComponent": "type=\"...\"",
        "react": "type={...}",
        "angular": "[type]=\"...\""
      }
    },
    {
      "name": "name",

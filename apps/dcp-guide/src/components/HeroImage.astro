---
import HeroBannerWrapper from './HeroBannerWrapper';
import homeImage from '../assets/HomeHero.png';
import storiesImage from '../assets/StoriesHero.png';
import learnMoreImage from '../assets/LearnMoreHero.png';
import whatIsHero from '../assets/WhatIsHero.png';
import whoIsInvolved from '../assets/WhoIsInvolvedHero.png';
export interface Props {
  title: string;
}

const { title } = Astro.props;
const getHeroImage = (title: string) =>{
   switch(title){
    case "Home":
        return homeImage.src;
    case "Who is Involved?":
        return whoIsInvolved.src;
    case "What is Modern Digital Delivery?":
        return whatIsHero.src;
    case "Stories" :
        return storiesImage.src;
    case "Learn More":
        return learnMoreImage.src;
    default:
        return "";              
   }
}
---

<HeroBannerWrapper client:only="react" title={title} backgroundUrl={getHeroImage(title)} />

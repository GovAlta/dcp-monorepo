---
import '@abgov/design-tokens/dist/tokens.css';
import '@abgov/web-components/index.css';
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroBanner from "./HeroBanner.astro";
import SideNav from "./SideNav.astro";

export interface Props {
  hideNav?: boolean;
  hideHero?: boolean;
}

const { hideNav = false, hideHero = true } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Digital standards</title>
		<script>
			const hostName = window.location.hostname;			
			if (hostName === 'digital.gov.ab.ca') {	
				(function () {
					// @ts-ignore
					window.dataLayer = window.dataLayer || [];
					function gtag() {
						// @ts-ignore
						dataLayer.push(arguments);
					}
					// @ts-ignore
					gtag('js', new Date());
					// @ts-ignore
					gtag('config', 'G-XZPW2XSJB8');
					const script = document.createElement('script');
					script.async = true;
					script.src =
						'https://www.googletagmanager.com/gtag/js?id=G-XZPW2XSJB8';
					
					const feedbackscript = document.createElement('script');
					feedbackscript.async = true;
					feedbackscript.src =
					'https://feedback-service.adsp.alberta.ca/feedback/v1/script/adspFeedback.js';	
					document.head.appendChild(script);	
					document.head.appendChild(feedbackscript);
				})();		
			}
			else if (hostName === 'digital-standards-dcp-uat.apps.aro.gov.ab.ca') {		
				(function () {
					// @ts-ignore
					window.dataLayer = window.dataLayer || [];
					function gtag() {
						// @ts-ignore
						dataLayer.push(arguments);
					}
					// @ts-ignore
					gtag('js', new Date());
					// @ts-ignore
					gtag('config', 'G-07PN9BK15G');
					const script = document.createElement('script');
					script.async = true;
					script.src =
						'https://www.googletagmanager.com/gtag/js?id=G-07PN9BK15G';
						
					const feedbackscript = document.createElement('script');
					feedbackscript.async = true;
					feedbackscript.src =
					'https://feedback-service.adsp-uat.alberta.ca/feedback/v1/script/adspFeedback.js';
					document.head.appendChild(script);
					document.head.appendChild(feedbackscript);
				})();				
			}			
		</script>
		<script>
			import '@abgov/web-components';
		</script>
		<script type="module"
			src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js">
	    </script>

		<script nomodule
			src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js">
		</script>

	</head>

	<body>
		<section id="top-page"></section>
		<Header />
		{!hideHero && <HeroBanner />}
		<goa-three-column-layout maxcontentwidth="1540px" rightcolumnwidth="30ch" leftcolumnwidth="35ch">
			{!hideNav && (
				<div slot="nav">
					<SideNav />
				</div>
			)}
			<div data-pagefind-body>
				<slot />
			</div>
		</goa-three-column-layout>
		<Footer />
	</body>
</html>


<style is:global>
	.line-elements {
		display: flex;
		flex-direction: row;
		gap: var(--goa-space-m);
		color: var(--goa-color-interactive-default);
	}
	.back-top {
		float: right;
	}	
</style>
